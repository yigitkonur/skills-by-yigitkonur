#!/usr/bin/env bash
# Pre-push hook: validates all skills before push, but does not block it.
#
# Setup (one-time):
#   git config core.hooksPath .githooks
#
# This hook runs scripts/validate-skills.py --quick (skips marketplace
# consistency to keep it fast). The full check runs in CI.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
VALIDATOR="$REPO_ROOT/scripts/validate-skills.py"

if [ ! -f "$VALIDATOR" ]; then
    echo "⚠️  scripts/validate-skills.py not found — skipping pre-push validation"
    exit 0
fi

echo "🔍 Validating skills before push..."
echo ""

if ! python3 "$VALIDATOR" --quick; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "⚠️  PUSH CONTINUES: skill validation failed"
    echo ""
    echo "  Check the validator output above for exact file-level fixes."
    echo ""
    echo "  Common fixes:"
    echo "    • Reference errors: route every references/*.md file from SKILL.md."
    echo "    • Length errors: keep SKILL.md under 500 lines by moving deep detail"
    echo "      into references/<topic>/... docs (nested folders are fine), then"
    echo "      link those files from SKILL.md."
    echo "    • Frontmatter/junk errors: follow the reported path and rule exactly."
    echo ""
    echo "  Re-run locally:"
    echo "    python3 scripts/validate-skills.py --quick"
    echo ""
    echo "  Push is continuing because validation is advisory here."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 0
fi

echo ""
echo "✅ All checks passed — pushing"
