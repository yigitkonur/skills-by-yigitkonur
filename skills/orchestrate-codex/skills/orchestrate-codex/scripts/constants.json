{
  "_description": "Single source of truth for numeric constants and policy defaults across orchestrate-codex. Read by _lib.sh::oc_load_constants and _lib.py::Constants. No script should hard-code these values; change them here and the whole skill picks them up.",
  "schema_version": 1,
  "monitor_hard_max_ms": 3600000,
  "lock_timeout_seconds": 30,
  "rescue_freshness_days": 7,
  "stale_tick_seconds": 60,
  "stale_multiplier": 3,
  "concurrency": {
    "defaults": {"exec": 5, "batch": 10, "single": 1, "review": 4},
    "soft_cap": 20,
    "hard_cap": 100
  },
  "audit": {
    "min_bytes_default": 10000,
    "stale_minutes_default": 30
  },
  "monitor": {
    "interval_default_sec": 30,
    "autostop_grace_default_sec": 0,
    "consec_warn_at_default": 3
  },
  "review": {
    "round_soft_cap": 10,
    "wall_clock_sec_per_round": 300
  },
  "codex": {
    "model_default": "gpt-5.5",
    "effort_default": "xhigh",
    "review_flags_arity": 2,
    "exec_flags_arity": 6
  },
  "exit_codes": {
    "_note": "Canonical exit-code map; runner-specific codes documented in each runner's --help.",
    "success": 0,
    "fallback_error": 1,
    "bad_input": 2,
    "environmental": 3,
    "lock_or_write_failed": 4,
    "missing_dependency": 5,
    "worktree_setup_hook_failed": 6,
    "signal": 143
  }
}
