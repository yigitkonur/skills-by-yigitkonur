{
  "_description": "Cross-language fixture: input manifest + mutation operation → expected on-disk JSON. Consumed by _lib.py::Manifest and the manifest-update.py refactor's regression tests.",
  "_atomic_write_recipe": {
    "1": "Acquire flock(<manifest>.lock, LOCK_EX) with timeout=30s",
    "2": "Post-lock re-read of manifest contents",
    "3": "Apply mutations to in-memory dict",
    "4": "tempfile.mkstemp(dir=parent, prefix='.manifest.', suffix='.tmp')",
    "5": "Write serialized JSON to temp file",
    "6": "os.replace(tmp_path, manifest_path)",
    "7": "Release lock (file persists; tidy removes on full clean)"
  },
  "cases": [
    {
      "name": "set_entry_status_to_running",
      "input": {
        "schema_version": 1,
        "run_id": "20260515T120000Z-a1b2",
        "mode": "exec",
        "entries": [
          {"id": "01-foo", "slug": "foo", "status": "queued", "attempts": 0}
        ]
      },
      "operations": [
        {"op": "set", "key": "entries[0].status", "value": "running"},
        {"op": "set", "key": "entries[0].attempts", "value": "+1"}
      ],
      "expected": {
        "schema_version": 1,
        "run_id": "20260515T120000Z-a1b2",
        "mode": "exec",
        "entries": [
          {"id": "01-foo", "slug": "foo", "status": "running", "attempts": 1}
        ]
      }
    },
    {
      "name": "history_row_appended_on_status_change",
      "input": {
        "schema_version": 1,
        "run_id": "20260515T120000Z-a1b2",
        "entries": [{"id": "01-foo", "status": "queued"}],
        "history": []
      },
      "operations": [
        {"op": "set", "key": "entries[0].status", "value": "running", "reason": "started", "actor": "run-fleet.sh"}
      ],
      "expected_history_row_keys": ["at", "actor", "reason", "from", "to", "attempts", "dry_run"],
      "expected_entry_status": "running"
    },
    {
      "name": "boolean_coercion_allowlist",
      "input": {
        "schema_version": 1,
        "entries": [{"id": "01-foo", "status": "queued", "mode_state": {"batch": {}}}]
      },
      "operations": [
        {"op": "set", "key": "entries[0].mode_state.batch.below_floor", "value": "true"},
        {"op": "set", "key": "entries[0].mode_state.exec.codex_pid", "value": "12345"},
        {"op": "set", "key": "entries[0].last_error", "value": "true"}
      ],
      "expected_types": {
        "entries[0].mode_state.batch.below_floor": "boolean",
        "entries[0].mode_state.exec.codex_pid": "number",
        "entries[0].last_error": "string"
      },
      "_note": "below_floor is on the allowlist → bool. codex_pid is on numeric allowlist → number. last_error is off both allowlists → stays as string 'true'."
    },
    {
      "name": "increment_missing_key_starts_at_zero",
      "input": {
        "schema_version": 1,
        "entries": [{"id": "01-foo", "status": "queued"}]
      },
      "operations": [
        {"op": "set", "key": "entries[0].attempts", "value": "+1"}
      ],
      "expected_entry": {"id": "01-foo", "status": "queued", "attempts": 1}
    }
  ]
}
