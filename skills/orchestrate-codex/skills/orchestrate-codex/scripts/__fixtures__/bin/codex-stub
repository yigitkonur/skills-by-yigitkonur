#!/usr/bin/env bash
# codex-stub — fake `codex` CLI for orchestrate-codex test fixtures
#
# Emits canned JSONL events on stdout, writes a canned answer file to the -o path,
# and exits with a configurable code. Used by run-parity.mjs to test orchestrate-codex
# without invoking the real codex binary.
#
# Behavior controlled via env vars:
#   STUB_SCENARIO   — preset: success | empty-answer | codex-exit-1 | thread-only | dry-run-events
#   STUB_EXIT_CODE  — override exit code (default: 0 for success, 1 for codex-exit-1)
#   STUB_THREAD_ID  — thread id used in events (default: "019e0a7e-stub-thread-id")
#   STUB_ANSWER     — answer body to write to -o (default: "stub answer\n")
#   STUB_EXTRA_JSONL — extra JSONL lines emitted before turn.completed

set -uo pipefail

# Parse codex args we care about
OUT_FILE=""
JSON_MODE=0
SUBCOMMAND=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    exec) SUBCOMMAND="exec"; shift;;
    review) SUBCOMMAND="review"; shift;;
    resume) SUBCOMMAND="resume"; shift;;
    --json) JSON_MODE=1; shift;;
    -o) OUT_FILE="$2"; shift 2;;
    --output) OUT_FILE="$2"; shift 2;;
    *) shift;;
  esac
done

SCENARIO="${STUB_SCENARIO:-success}"
THREAD_ID="${STUB_THREAD_ID:-019e0a7e-stub-thread-id}"
ANSWER="${STUB_ANSWER:-stub answer\n}"

emit_jsonl() {
  printf '%s\n' "$1"
}

case "$SCENARIO" in
  success)
    emit_jsonl '{"type":"thread.started","thread_id":"'"$THREAD_ID"'"}'
    emit_jsonl '{"type":"item.completed","item":{"type":"reasoning","content":"thinking about it"}}'
    emit_jsonl '{"type":"item.completed","item":{"type":"agent_message","message":"done.","phase":"final_answer"}}'
    emit_jsonl '{"type":"turn.completed","input_tokens":120,"output_tokens":35,"cached_input_tokens":0}'
    [[ -n "$OUT_FILE" ]] && printf '%b' "$ANSWER" > "$OUT_FILE"
    exit "${STUB_EXIT_CODE:-0}"
    ;;
  empty-answer)
    emit_jsonl '{"type":"thread.started","thread_id":"'"$THREAD_ID"'"}'
    emit_jsonl '{"type":"turn.completed","input_tokens":50,"output_tokens":0,"cached_input_tokens":0}'
    [[ -n "$OUT_FILE" ]] && : > "$OUT_FILE"
    exit "${STUB_EXIT_CODE:-0}"
    ;;
  codex-exit-1)
    emit_jsonl '{"type":"thread.started","thread_id":"'"$THREAD_ID"'"}'
    emit_jsonl '{"type":"error","message":"simulated codex failure"}' >&2
    exit "${STUB_EXIT_CODE:-1}"
    ;;
  thread-only)
    emit_jsonl '{"type":"thread.started","thread_id":"'"$THREAD_ID"'"}'
    exit "${STUB_EXIT_CODE:-0}"
    ;;
  rate-limit)
    echo "503 Service Unavailable" >&2
    exit "${STUB_EXIT_CODE:-1}"
    ;;
  --version)
    echo "codex 0.130.0-stub"
    exit 0
    ;;
  *)
    echo "codex-stub: unknown STUB_SCENARIO=$SCENARIO" >&2
    exit 2
    ;;
esac
