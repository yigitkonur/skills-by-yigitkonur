#!/usr/bin/env bash
# skill-dl — pure-bash skill discovery and downloader for build-skill.
#
# Subcommands:
#   skill-dl <url|file|-> [...] [-o DIR] [-c CAT] [--no-auto-category] [-f] [--dry-run] [-v]
#   skill-dl search <kw1> <kw2> <kw3> [...] [--top N] [--min-match N]
#   skill-dl --help | --where | --version
#
# Discovery channels (search):
#   1. `npx -y skills find <kw>` — primary, no API key, requires npx in PATH.
#   2. Serper Google API — optional, runs only if SERPER_API_KEY is set.
#
# Download mechanism:
#   git clone --depth 1 https://github.com/<owner>/<repo>, locate the skill
#   directory (mirrors the original Go skill-dl search paths), copy contents.
#
# No proxy dependency (Scrapedo removed). No install required.

set -euo pipefail

VERSION="2.0.0-bash"

# ---------------------------------------------------------------- formatting
INFO()    { printf '[INFO] %s\n' "$*" >&2; }
WARN()    { printf '[WARN] %s\n' "$*" >&2; }
ERROR()   { printf '[ERR]  %s\n' "$*" >&2; }
SUCCESS() { printf '[OK]   %s\n' "$*" >&2; }

strip_ansi() { sed $'s/\x1B\\[[0-9;]*[a-zA-Z]//g'; }

# ----------------------------------------------------------------- show_help
show_help() {
  cat <<'EOF'
skill-dl — pure-bash skill discovery & downloader (no install required)

USAGE
  skill-dl <source> [options]            Download one or more skills
  skill-dl search <kw> <kw> <kw> ...     Search for skills (3-20 keywords)
  skill-dl --where                       Print resolution info as JSON
  skill-dl --version                     Print version
  skill-dl --help                        Show this help

SOURCE
  <url>     A playbooks.com/skills.sh URL, or owner/repo/skill triple.
  <file>    Text file with one URL per line (# for comments).
  -         Read URLs from stdin.

OPTIONS (download)
  -o, --output <dir>     Output directory (default: ./skills-collection)
  -c, --category <name>  Force all skills into this category folder
  --no-auto-category     Flat structure, no category folders
  -f, --force            Overwrite existing skill directories
  --dry-run              Preview without downloading
  -v, --verbose          More logging

OPTIONS (search)
  --top <N>          Cap results (default: all)
  --min-match <N>    Minimum keyword-match count to include (default: 1)

ENVIRONMENT
  SERPER_API_KEY     Optional. If set, layers Serper Google results on top
                     of `npx skills find`. If unset, search uses npx only.

DISCOVERY
  Primary:  `npx -y skills find <keyword>`     (no API key, requires npx)
  Layered:  Serper API if SERPER_API_KEY set   (https://serper.dev)

URL FORMS
  https://playbooks.com/skills/<owner>/<repo>/<skill>
  https://skills.sh/<owner>/<repo>/<skill>
  <owner>/<repo>/<skill>

EXAMPLES
  skill-dl search typescript mcp server --top 20
  skill-dl https://playbooks.com/skills/mcollina/skills/typescript-magician
  skill-dl urls.txt -o ./corpus --no-auto-category -f
  echo vercel-labs/agent-skills/vercel-react-best-practices | skill-dl -

DEPENDENCIES
  bash 4+, git, curl, npx (Node.js). No SCRAPEDO key needed; no Go binary.
EOF
}

# ------------------------------------------------------------- prerequisites
require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    ERROR "missing required command: $1"
    return 1
  fi
}

# ------------------------------------------------------------------ url parse
parse_url() {
  local raw="${1%/}"
  local stripped="$raw"
  case "$stripped" in
    https://playbooks.com/skills/*) stripped="${stripped#https://playbooks.com/skills/}" ;;
    https://skills.sh/*)            stripped="${stripped#https://skills.sh/}" ;;
    http://playbooks.com/skills/*)  stripped="${stripped#http://playbooks.com/skills/}" ;;
    http://skills.sh/*)             stripped="${stripped#http://skills.sh/}" ;;
    *://*)                          return 1 ;;
  esac

  local count
  count=$(awk -F'/' '{print NF}' <<<"$stripped")
  if [[ "$count" -lt 3 ]]; then
    return 1
  fi
  OWNER="$(cut -d/ -f1 <<<"$stripped")"
  REPO="$(cut -d/ -f2 <<<"$stripped")"
  SKILL="$(cut -d/ -f3- <<<"$stripped")"
  [[ -n "$OWNER" && -n "$REPO" && -n "$SKILL" ]] || return 1
  return 0
}

canonical_url() {
  printf 'https://playbooks.com/skills/%s/%s/%s\n' "$1" "$2" "$3"
}

# ------------------------------------------------------------ auto categorize
auto_categorize() {
  local skill="${1,,}"
  case "$skill" in
    *react-typescript*|*react-ts*|*nextjs-typescript*|*next-ts*) echo "react-typescript" ;;
    *strict*|*advanced-type*|*type-expert*|*guardian*|*detector*|*advanced-pattern*) echo "strict-and-types" ;;
    *sdk*|*ts-library*|*typescript-v*|*library*) echo "sdk-and-libraries" ;;
    *review*|*reviewer*|*pro-skill*|*magician*|*code-review*) echo "pro-and-review" ;;
    *generator*|*setup*|*init*|*tdd-*|*circular*|*tooling*|*lang-typescript*|*bun-*) echo "tooling-and-setup" ;;
    *coding-standard*|*code-standard*|*clean-code*|*code-style*|*best-practice*|*check-try*) echo "code-quality" ;;
    *typescript*|*expert*|*clean-typescript*|*javascript-typescript*) echo "best-practices" ;;
    *) echo "general" ;;
  esac
}

# ----------------------------------------------------------- find skill dir
find_skill_dir() {
  local repo_dir="$1" skill="$2"
  local known=(
    "skills/$skill"
    "$skill"
    ".skills/$skill"
    ".claude/skills/$skill"
    ".agent/skills/$skill"
    ".opencode/skills/$skill"
    ".cursor/skills/$skill"
    ".agents/skills/$skill"
    "src/skills/$skill"
  )
  local p
  for p in "${known[@]}"; do
    if [[ -f "$repo_dir/$p/SKILL.md" ]]; then
      printf '%s\tsub\n' "$repo_dir/$p"
      return 0
    fi
  done
  local found
  found=$(find "$repo_dir" -type d -name .git -prune -o -type f -name SKILL.md -print 2>/dev/null \
    | while IFS= read -r path; do
        parent=$(dirname "$path")
        if [[ "$(basename "$parent")" == "$skill" ]]; then
          printf '%s\n' "$parent"; break
        fi
      done)
  if [[ -n "$found" ]]; then
    printf '%s\tsub\n' "$found"
    return 0
  fi
  if [[ -f "$repo_dir/SKILL.md" ]]; then
    printf '%s\troot\n' "$repo_dir"
    return 0
  fi
  return 1
}

exclude_root_entry() {
  local name="$1" is_dir="$2"
  if [[ "$is_dir" == "1" ]]; then
    case "$name" in
      .git|.github|.gitlab|node_modules|.vscode|.idea) return 0 ;;
      *) return 1 ;;
    esac
  else
    case "$name" in
      README.md|LICENSE|LICENSE.md|CHANGELOG.md|CONTRIBUTING.md|CODE_OF_CONDUCT.md|SECURITY.md) return 0 ;;
      .gitignore|.gitattributes|package.json|package-lock.json|yarn.lock|pnpm-lock.yaml|bun.lockb) return 0 ;;
      *) return 1 ;;
    esac
  fi
}

copy_skill() {
  local src="$1" dst="$2" at_root="$3"
  rm -rf "$dst"
  mkdir -p "$dst"
  shopt -s dotglob nullglob
  local entry name is_dir
  for entry in "$src"/*; do
    [[ -e "$entry" ]] || continue
    name=$(basename "$entry")
    is_dir=0; [[ -d "$entry" ]] && is_dir=1
    if [[ "$at_root" == "1" ]] && exclude_root_entry "$name" "$is_dir"; then
      continue
    fi
    if [[ -d "$entry" ]]; then
      cp -R "$entry" "$dst/$name"
    else
      cp -p "$entry" "$dst/$name"
    fi
  done
  shopt -u dotglob nullglob
  rm -rf "$dst/.git"
  find "$dst" -type f 2>/dev/null | wc -l | tr -d ' '
}

# -------------------------------------------------------- read source list
collect_urls_from_reader() {
  local line
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="${line## }"; line="${line%% }"
    [[ -n "$line" ]] || continue
    printf '%s\n' "$line"
  done
}

collect_urls() {
  local sources=("$@")
  local s
  if [[ "${#sources[@]}" -eq 0 ]]; then
    ERROR "no source provided"
    return 1
  fi
  for s in "${sources[@]}"; do
    case "$s" in
      -)
        collect_urls_from_reader
        ;;
      http://*|https://*)
        printf '%s\n' "$s"
        ;;
      *)
        if [[ -f "$s" ]]; then
          collect_urls_from_reader < "$s"
        elif [[ "$s" == */*/* ]]; then
          printf '%s\n' "$s"
        else
          ERROR "source not recognized: $s (expected URL, file, '-', or owner/repo/skill)"
          return 1
        fi
        ;;
    esac
  done
}

# =========================================================== DOWNLOAD MODE
do_download() {
  local out_dir="./skills-collection"
  local force_category=""
  local auto_categorize_flag=1
  local force=0 dry_run=0 verbose=0
  local sources=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -o|--output)            shift; out_dir="${1:?}";;
      -c|--category)          shift; force_category="${1:?}"; auto_categorize_flag=0;;
      --no-auto-category)     auto_categorize_flag=0;;
      -f|--force)             force=1;;
      --dry-run)              dry_run=1;;
      -v|--verbose)           verbose=1;;
      -h|--help)              show_help; return 0;;
      --) shift; sources+=("$@"); break;;
      -)  sources+=("-");;
      -*) ERROR "unknown option: $1"; return 2;;
      *)  sources+=("$1");;
    esac
    shift || true
  done

  require_cmd git || return 2

  local urls
  urls=$(collect_urls "${sources[@]}") || return 2
  [[ -n "$urls" ]] || { ERROR "no urls found in provided sources"; return 2; }

  urls=$(awk '!seen[$0]++' <<<"$urls")

  local total=0 ok=0 fail=0 skip=0
  declare -A repo_groups=()
  declare -a repo_order=()
  declare -a failed_urls=()
  local raw key

  while IFS= read -r raw; do
    [[ -n "$raw" ]] || continue
    total=$((total+1))
    if ! parse_url "$raw"; then
      ERROR "invalid url (skipped): $raw"
      fail=$((fail+1)); failed_urls+=("$raw")
      continue
    fi
    key="$OWNER/$REPO"
    if [[ -z "${repo_groups[$key]+x}" ]]; then
      repo_order+=("$key")
      repo_groups[$key]=""
    fi
    repo_groups[$key]+="$SKILL"$'\t'"$raw"$'\n'
  done <<<"$urls"

  printf '\nskill-dl v%s\nDownloading %d skill(s) into: %s\n\n' "$VERSION" "$total" "$out_dir" >&2

  local current=0 clone_dir="" clone_ok category dest folder_name display_dest
  local skill_name raw_url loc loc_path loc_kind file_count owner_short repo_short

  for key in "${repo_order[@]}"; do
    clone_ok=1
    if [[ "$dry_run" == "0" ]]; then
      clone_dir=$(mktemp -d -t skill-dl-XXXXXX)
      if ! git clone --depth 1 --quiet "https://github.com/$key.git" "$clone_dir" 2>/dev/null; then
        ERROR "could not clone github.com/$key"
        clone_ok=0
      fi
    fi

    owner_short="${key%%/*}"
    repo_short="${key#*/}"

    while IFS=$'\t' read -r skill_name raw_url; do
      [[ -n "$skill_name" ]] || continue
      current=$((current+1))

      if [[ -n "$force_category" ]]; then
        category="$force_category"
      elif [[ "$auto_categorize_flag" == "1" ]]; then
        category=$(auto_categorize "$skill_name")
      else
        category=""
      fi
      folder_name="$owner_short--$repo_short--$skill_name"
      if [[ -n "$category" ]]; then
        dest="$out_dir/$category/$folder_name"
        display_dest="${out_dir%/}/$category/$folder_name"
      else
        dest="$out_dir/$folder_name"
        display_dest="${out_dir%/}/$folder_name"
      fi

      if [[ "$dry_run" == "1" ]]; then
        INFO "[$current/$total] $owner_short/$repo_short/$skill_name → $display_dest"
        skip=$((skip+1))
        continue
      fi

      if [[ "$clone_ok" == "0" ]]; then
        ERROR "[$current/$total] $skill_name — repo unavailable"
        fail=$((fail+1)); failed_urls+=("$raw_url")
        continue
      fi

      if [[ -e "$dest" && "$force" == "0" ]]; then
        WARN "[$current/$total] exists: $folder_name (--force to overwrite)"
        skip=$((skip+1))
        continue
      fi

      INFO "[$current/$total] $skill_name"
      if ! loc=$(find_skill_dir "$clone_dir" "$skill_name"); then
        ERROR "  not found in repo"
        fail=$((fail+1)); failed_urls+=("$raw_url")
        continue
      fi
      loc_path="${loc%%$'\t'*}"
      loc_kind="${loc##*$'\t'}"
      [[ "$verbose" == "1" ]] && INFO "  source: $loc_path ($loc_kind)"
      local at_root=0
      [[ "$loc_kind" == "root" ]] && at_root=1
      if file_count=$(copy_skill "$loc_path" "$dest" "$at_root"); then
        if [[ -n "$category" ]]; then
          SUCCESS "  $file_count files → $category/$folder_name"
        else
          SUCCESS "  $file_count files → $folder_name"
        fi
        ok=$((ok+1))
      else
        ERROR "  copy failed"
        fail=$((fail+1)); failed_urls+=("$raw_url")
      fi
    done <<<"${repo_groups[$key]}"

    if [[ -n "${clone_dir:-}" && -d "${clone_dir:-}" ]]; then
      rm -rf "$clone_dir"
    fi
    clone_dir=""
  done

  {
    printf '\n━━━ Summary ━━━\n'
    printf '  Total:   %d\n' "$total"
    [[ "$ok"   -gt 0 ]] && printf '  Success: %d\n' "$ok"
    [[ "$skip" -gt 0 ]] && printf '  Skipped: %d\n' "$skip"
    [[ "$fail" -gt 0 ]] && printf '  Failed:  %d\n' "$fail"
    if [[ "${#failed_urls[@]}" -gt 0 ]]; then
      printf '\nFailed URLs:\n'
      local u; for u in "${failed_urls[@]}"; do printf '  %s\n' "$u"; done
    fi
    [[ "$dry_run" == "0" && "$ok" -gt 0 ]] && printf '\nOutput: %s\n' "$out_dir"
    printf '\n'
  } >&2

  [[ "$fail" -eq 0 ]]
}

# ============================================================== SEARCH MODE
search_npx() {
  local kw="$1"
  command -v npx >/dev/null 2>&1 || return 0
  npx -y skills@latest find "$kw" 2>/dev/null \
    | strip_ansi \
    | grep -oE '[A-Za-z0-9._-]+/[A-Za-z0-9._-]+@[A-Za-z0-9._:-]+' \
    | grep -vx 'owner/repo@skill' \
    | sed 's#@#/#' \
    | sort -u
}

search_serper() {
  local kw="$1" key="${SERPER_API_KEY:-}"
  [[ -n "$key" ]] || return 0
  command -v curl >/dev/null 2>&1 || return 0
  local payload body
  payload=$(printf '{"q":"site:playbooks.com/skills %s","num":30}' "$kw")
  body=$(curl -s -X POST 'https://google.serper.dev/search' \
    -H "X-API-KEY: $key" -H 'Content-Type: application/json' \
    -d "$payload" 2>/dev/null) || return 0
  grep -oE 'https://playbooks\.com/skills/[A-Za-z0-9._/-]+' <<<"$body" \
    | sed -E 's#^https://playbooks\.com/skills/##; s#/$##' \
    | awk -F/ 'NF>=3 {print $1 "/" $2 "/" $3}' \
    | sort -u
}

do_search() {
  local top=0 min_match=1
  local keywords=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --top)        shift; top="${1:?}";;
      --min-match)  shift; min_match="${1:?}";;
      -h|--help)    show_help; return 0;;
      -*) ERROR "unknown search option: $1"; return 2;;
      *)  keywords+=("$1");;
    esac
    shift || true
  done

  if [[ "${#keywords[@]}" -lt 3 ]]; then
    ERROR "search requires at least 3 keywords (got ${#keywords[@]})"
    return 2
  fi
  if [[ "${#keywords[@]}" -gt 20 ]]; then
    ERROR "search accepts at most 20 keywords (got ${#keywords[@]})"
    return 2
  fi

  INFO "searching for ${#keywords[@]} keyword(s)..."
  if command -v npx >/dev/null 2>&1; then
    INFO "channel: npx skills find (primary)"
  else
    WARN "channel: npx skills find (UNAVAILABLE — install Node.js)"
  fi
  if [[ -n "${SERPER_API_KEY:-}" ]]; then
    INFO "channel: Serper API (layered, SERPER_API_KEY detected)"
  else
    INFO "channel: Serper API (skipped — set SERPER_API_KEY to enable)"
  fi

  declare -A counts=()
  declare -A matched_keywords=()
  local kw triple raw=0

  for kw in "${keywords[@]}"; do
    declare -A per_kw=()
    while IFS= read -r triple; do
      [[ -n "$triple" ]] || continue
      per_kw[$triple]=1
    done < <(search_npx "$kw")
    while IFS= read -r triple; do
      [[ -n "$triple" ]] || continue
      per_kw[$triple]=1
    done < <(search_serper "$kw")

    raw=$((raw + ${#per_kw[@]}))
    for triple in "${!per_kw[@]}"; do
      counts[$triple]=$((${counts[$triple]:-0} + 1))
      if [[ -z "${matched_keywords[$triple]:-}" ]]; then
        matched_keywords[$triple]="$kw"
      else
        matched_keywords[$triple]+=", $kw"
      fi
    done
    unset per_kw
  done

  INFO "raw results: $raw skill references across ${#keywords[@]} keywords"
  INFO "aggregating..."

  local sorted
  sorted=$(
    for triple in "${!counts[@]}"; do
      [[ "${counts[$triple]}" -ge "$min_match" ]] || continue
      printf '%d\t%s\n' "${counts[$triple]}" "$triple"
    done | sort -t$'\t' -k1,1nr -k2,2
  )

  if [[ -z "$sorted" ]]; then
    ERROR "no skills found matching the given keywords (min-match=$min_match)"
    return 1
  fi

  local total_matched
  total_matched=$(wc -l <<<"$sorted" | tr -d ' ')
  if [[ "$top" -gt 0 ]]; then
    sorted=$(head -n "$top" <<<"$sorted")
  fi
  local shown
  shown=$(wc -l <<<"$sorted" | tr -d ' ')

  printf '| # | Skill | Owner/Repo | Keywords Matched | Match Count | URL |\n'
  printf '|---|-------|------------|-----------------|-------------|-----|\n'
  local idx=0 count owner repo skill_seg
  while IFS=$'\t' read -r count triple; do
    [[ -n "$count" ]] || continue
    idx=$((idx+1))
    owner="${triple%%/*}"
    repo="${triple#*/}"; repo="${repo%%/*}"
    skill_seg="${triple#*/*/}"
    printf '| %d | %s | %s/%s | %s | %s | %s |\n' \
      "$idx" "$skill_seg" "$owner" "$repo" "${matched_keywords[$triple]}" "$count" \
      "$(canonical_url "$owner" "$repo" "$skill_seg")"
  done <<<"$sorted"

  printf '\n' >&2
  INFO "done. $shown skill(s) shown (from $total_matched total matched)."
}

# ===================================================================== main
case "${1:-}" in
  -h|--help)    show_help; exit 0;;
  --version)    printf 'skill-dl v%s\n' "$VERSION"; exit 0;;
  --where)      printf '{"status":"ready","source":"bundled-bash","path":"%s"}\n' "${BASH_SOURCE[0]}"; exit 0;;
  --tool-help)  show_help; exit 0;;
  search)       shift; do_search "$@"; exit $?;;
  "")           show_help; exit 2;;
  *)            do_download "$@"; exit $?;;
esac
